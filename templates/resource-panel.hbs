{{!-- Resource Tracker Panel --}}
<div class="dsresources-panel">

  {{#if noCharacter}}
  {{#if isGM}}
  <div class="dsresources-no-character">
    <i class="fa-solid fa-user-slash"></i>
    <p>{{localize "DSRESOURCES.NoCharacterGM"}}</p>
  </div>
  {{else}}
  <div class="dsresources-no-character">
    <i class="fa-solid fa-user-slash"></i>
    <p>{{localize "DSRESOURCES.NoCharacter"}}</p>
  </div>
  {{/if}}
  {{else}}

  {{!-- ── GM character selector bar ───────────────────────────────────── --}}
  {{#if isGM}}
  <nav class="dsresources-hero-bar">
    {{#each heroList}}
    <button type="button"
      class="dsresources-hero-btn {{#if this.isSelected}}active{{/if}}"
      data-action="switchCharacter" data-actor-id="{{this.id}}">
      {{this.name}}
    </button>
    {{/each}}
  </nav>
  {{/if}}

  {{!-- ── Persistent values row (always visible) ────────────────────── --}}
  <div class="dsresources-values-row">
    <hr class="dsresources-divider" />
    <div class="dsresources-values-columns">

      {{!-- Heroic Resource column --}}
      <div class="dsresources-value-col">
        <div class="dsresources-value-display">
          <button type="button" class="dsresources-adj-btn" data-action="decrementHeroic"
            title="{{localize 'DSRESOURCES.Tooltip.Decrease'}}">
            <i class="fa-solid fa-minus"></i>
          </button>
          <span class="dsresources-value">{{heroicValue}}</span>
          <button type="button" class="dsresources-adj-btn" data-action="incrementHeroic"
            title="{{localize 'DSRESOURCES.Tooltip.Increase'}}">
            <i class="fa-solid fa-plus"></i>
          </button>
        </div>
      </div>

      <div class="dsresources-value-divider"></div>

      {{!-- Surge column --}}
      <div class="dsresources-value-col">
        <div class="dsresources-value-display">
          <button type="button" class="dsresources-adj-btn" data-action="decrementSurge"
            title="{{localize 'DSRESOURCES.Tooltip.Decrease'}}">
            <i class="fa-solid fa-minus"></i>
          </button>
          <span class="dsresources-value">{{surgeValue}}</span>
          <button type="button" class="dsresources-adj-btn" data-action="incrementSurge"
            title="{{localize 'DSRESOURCES.Tooltip.Increase'}}">
            <i class="fa-solid fa-plus"></i>
          </button>
        </div>
      </div>

      {{#if heroTokenAvailable}}
      <div class="dsresources-value-divider"></div>

      {{!-- Hero Token column --}}
      <div class="dsresources-value-col">
        <div class="dsresources-value-display">
          {{#if isGM}}
          <button type="button" class="dsresources-adj-btn" data-action="decrementToken"
            title="{{localize 'DSRESOURCES.Tooltip.Decrease'}}">
            <i class="fa-solid fa-minus"></i>
          </button>
          {{/if}}
          <span class="dsresources-value">{{heroTokenValue}}</span>
          {{#if isGM}}
          <button type="button" class="dsresources-adj-btn" data-action="incrementToken"
            title="{{localize 'DSRESOURCES.Tooltip.Increase'}}">
            <i class="fa-solid fa-plus"></i>
          </button>
          {{/if}}
        </div>
      </div>
      {{/if}}

    </div>

  </div>

  {{!-- ── Tab bar ─────────────────────────────────────────────────────── --}}
  <nav class="dsresources-tabs">
    <button type="button" class="dsresources-tab {{#if (eq activeTab 'heroic')}}active{{/if}}"
      data-action="switchTab" data-tab="heroic">
      {{resourceName}}
    </button>
    <button type="button" class="dsresources-tab {{#if (eq activeTab 'surge')}}active{{/if}}"
      data-action="switchTab" data-tab="surge">
      {{localize "DSRESOURCES.Tabs.Surge"}}
    </button>
    {{#if heroTokenAvailable}}
    <button type="button" class="dsresources-tab {{#if (eq activeTab 'heroToken')}}active{{/if}}"
      data-action="switchTab" data-tab="heroToken">
      {{localize "DSRESOURCES.Tabs.HeroToken"}}
    </button>
    {{/if}}
  </nav>
  <hr class="dsresources-tab-divider">

  <section class="dsresources-tab-content">

    {{!-- ════════════════════════════════════════════════════════════════
         HEROIC RESOURCE TAB
         ════════════════════════════════════════════════════════════════ --}}
    {{#if (eq activeTab "heroic")}}
    <div class="dsresources-tab-pane" data-tab="heroic">

      {{#if noClassData}}
      <p class="dsresources-empty">{{localize "DSRESOURCES.NoClassData"}}</p>
      {{else}}

      {{!-- ── Class Feature section (Mantle / Strain) ─────────────────── --}}
      {{#if classFeature}}
      <div class="dsresources-section dsresources-class-feature">
        <div class="dsresources-class-feature-header">
          {{#if classFeature.isActive}}
          <span class="dsresources-class-feature-status dsresources-class-feature--{{classFeature.activeColor}}">{{classFeature.label}}</span>
          {{else}}
          <span class="dsresources-class-feature-status dsresources-class-feature--inactive">
            {{#if classFeature.inactiveLabel}}{{classFeature.inactiveLabel}}{{else}}{{classFeature.label}}: {{localize "DSRESOURCES.Mantle.Inactive"}}{{/if}}
          </span>
          {{/if}}
          {{#if (eq classFeature.type "strain")}}
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--danger"
            data-action="strainDamage" {{#unless classFeature.isActive}}disabled{{/unless}}>
            <i class="fa-solid fa-heart-crack"></i>
            {{localize "DSRESOURCES.Talent.StrainBtn"}}
          </button>
          {{/if}}
        </div>
        {{#if classFeature.description}}
        <div class="dsresources-class-feature-desc">{{{classFeature.description}}}</div>
        {{/if}}
      </div>
      <hr class="dsresources-divider" />
      {{/if}}

      {{!-- ── Gain section ────────────────────────────────────────────── --}}
      <div class="dsresources-section">
        <h3 class="dsresources-section-title">{{localize "DSRESOURCES.Section.Gain"}}</h3>
        {{#each gains}}
        {{#if this.isGroupHeader}}
        {{!-- Group header (e.g. Melodrama), description only, no button --}}
        <div class="dsresources-entry dsresources-entry--group-header">
          <span class="dsresources-entry-desc">{{{this.description}}}</span>
        </div>
        {{#each this.children}}
        <div class="dsresources-entry dsresources-entry--child">
          <span class="dsresources-entry-desc">{{{this.description}}}</span>
          {{#if this.isUsed}}
          <button type="button" class="dsresources-undo-btn" data-action="undoUsage" data-track-key="{{this.trackKey}}"
            title="{{localize 'DSRESOURCES.Tooltip.Undo'}}">
            <i class="fa-solid fa-rotate-left"></i>
          </button>
          {{/if}}
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--gain"
            data-action="gainHeroic" data-gain-id="{{this.id}}"
            {{#if this.isUsed}}disabled{{/if}}>
            {{this.label}}
          </button>
        </div>
        {{/each}}
        {{else}}
        <div class="dsresources-entry">
          <span class="dsresources-entry-desc">{{{this.description}}}</span>
          {{#if this.isDescriptionOnly}}
          {{!-- No button for description-only gains --}}
          {{else if this.isPray}}
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--pray"
            data-action="prayHeroic" data-gain-id="{{this.id}}">
            {{this.label}}
          </button>
          {{else if this.isMindRecovery}}
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--recovery"
            data-action="mindRecovery" data-gain-id="{{this.id}}">
            {{this.label}}
          </button>
          {{else}}
          {{#if this.isUsed}}
          <button type="button" class="dsresources-undo-btn" data-action="undoUsage" data-track-key="{{this.trackKey}}"
            title="{{localize 'DSRESOURCES.Tooltip.Undo'}}">
            <i class="fa-solid fa-rotate-left"></i>
          </button>
          {{/if}}
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--gain"
            data-action="gainHeroic" data-gain-id="{{this.id}}"
            {{#if this.isAutomated}}disabled title="Handled automatically by the system"{{else if this.isUsed}}disabled{{/if}}>
            {{this.label}}
          </button>
          {{/if}}
        </div>
        {{/if}}
        {{/each}}
      </div>

      <hr class="dsresources-divider" />

      {{!-- ── Spend section ───────────────────────────────────────────── --}}
      <div class="dsresources-section">
        <h3 class="dsresources-section-title">{{localize "DSRESOURCES.Section.Spend"}}</h3>
        {{#each spends}}
        {{#if this.isGroupHeader}}
        {{!-- Group header (e.g. Psi Boost), description only, no button --}}
        <div class="dsresources-entry dsresources-entry--group-header">
          <span class="dsresources-entry-desc">{{{this.description}}}</span>
        </div>
        {{#each this.children}}
        <div class="dsresources-entry dsresources-entry--child">
          <span class="dsresources-entry-desc">{{{this.description}}}</span>
          {{#if this.isUsed}}
          <button type="button" class="dsresources-undo-btn" data-action="undoUsage" data-track-key="{{this.trackKey}}"
            title="{{localize 'DSRESOURCES.Tooltip.Undo'}}">
            <i class="fa-solid fa-rotate-left"></i>
          </button>
          {{/if}}
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--spend"
            data-action="spendHeroic" data-spend-id="{{this.id}}"
            {{#if this.isUsed}}disabled{{/if}}>
            {{this.label}}
          </button>
        </div>
        {{/each}}
        {{else if this.isDescriptionOnly}}
        {{!-- Description-only entry (e.g. Manifold Resonance), no button --}}
        <div class="dsresources-entry">
          <span class="dsresources-entry-desc">{{{this.description}}}</span>
        </div>
        {{else}}
        <div class="dsresources-entry">
          <span class="dsresources-entry-desc">{{{this.description}}}</span>
          {{#if this.isSpendX}}
          {{#if this.isUsed}}
          <button type="button" class="dsresources-undo-btn" data-action="undoUsage" data-track-key="{{this.trackKey}}"
            title="{{localize 'DSRESOURCES.Tooltip.Undo'}}">
            <i class="fa-solid fa-rotate-left"></i>
          </button>
          {{/if}}
          <div class="dsresources-spendx-inline">
            <button type="button" class="dsresources-spendx-adj"
              data-action="adjustSpendX" data-spend-id="{{this.id}}" data-direction="-1"
              {{#if this.isUsed}}disabled{{/if}}>
              <i class="fa-solid fa-minus"></i>
            </button>
            <span class="dsresources-spendx-value">{{this.spendXValue}}</span>
            <button type="button" class="dsresources-spendx-adj"
              data-action="adjustSpendX" data-spend-id="{{this.id}}" data-direction="1"
              {{#if this.isUsed}}disabled{{/if}}>
              <i class="fa-solid fa-plus"></i>
            </button>
            <button type="button" class="dsresources-entry-btn {{#if this.grantsSurgePerSpend}}dsresources-entry-btn--surge{{else}}dsresources-entry-btn--spend{{/if}}"
              data-action="confirmSpendX" data-spend-id="{{this.id}}"
              {{#if this.isUsed}}disabled{{/if}}>
              {{this.label}}
            </button>
          </div>
          {{else}}
          {{#if this.isUsed}}
          <button type="button" class="dsresources-undo-btn" data-action="undoUsage" data-track-key="{{this.trackKey}}"
            title="{{localize 'DSRESOURCES.Tooltip.Undo'}}">
            <i class="fa-solid fa-rotate-left"></i>
          </button>
          {{/if}}
          <button type="button" class="dsresources-entry-btn {{#if this.grantsSurge}}dsresources-entry-btn--surge{{else}}dsresources-entry-btn--spend{{/if}}"
            data-action="spendHeroic" data-spend-id="{{this.id}}"
            {{#if this.isUsed}}disabled{{/if}}>
            {{this.label}}
          </button>
          {{/if}}
        </div>
        {{/if}}
        {{/each}}
      </div>

      <hr class="dsresources-divider" />

      {{!-- ── Growth Tables (e.g. Growing Ferocity) ───────────────────── --}}
      {{#each growthTables}}
      <div class="dsresources-section">
        <h3 class="dsresources-section-title">{{this.label}}</h3>
        {{#if this.description}}
        <div class="dsresources-growth-description">{{{this.description}}}</div>
        {{/if}}
        <table class="dsresources-growth-table">
          <thead>
            <tr>
              <th class="dsresources-growth-threshold">{{localize "DSRESOURCES.Table.Threshold"}}</th>
              <th>{{localize "DSRESOURCES.Table.Effect"}}</th>
              <th class="dsresources-growth-action"></th>
            </tr>
          </thead>
          <tbody>
            {{#each this.rows}}
            <tr class="{{#if this.isActive}}dsresources-growth-active{{/if}}">
              <td class="dsresources-growth-threshold">{{this.threshold}}</td>
              <td class="dsresources-growth-effect">{{{this.description}}}</td>
              <td class="dsresources-growth-action">
                {{#if this.showSurgeButton}}
                {{#if this.isUsed}}
                <button type="button" class="dsresources-undo-btn" data-action="undoUsage" data-track-key="{{this.trackKey}}"
                  title="{{localize 'DSRESOURCES.Tooltip.Undo'}}">
                  <i class="fa-solid fa-rotate-left"></i>
                </button>
                {{/if}}
                <button type="button" class="dsresources-entry-btn dsresources-entry-btn--gain dsresources-growth-surge-btn"
                  data-action="gainGrowthSurge" data-surge-amount="{{this.surgeButtonAmount}}"
                  data-table-label="{{../label}}"
                  data-track-key="{{this.trackKey}}"
                  title="Gain {{this.surgeButtonAmount}} surge(s)"
                  {{#if this.isUsed}}disabled{{/if}}>
                  +{{this.surgeButtonAmount}}
                </button>
                {{/if}}
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{/each}}

      {{!-- ── Passive effects toggle ──────────────────────────────────── --}}
      {{#if hasPassiveEffects}}
      <div class="dsresources-section">
        <button type="button" class="dsresources-toggle-btn" data-action="togglePassives">
          <i class="fa-solid {{#if showPassives}}fa-chevron-up{{else}}fa-chevron-down{{/if}}"></i>
          {{localize "DSRESOURCES.Section.Passives"}}
        </button>
        {{#if showPassives}}
        <table class="dsresources-passives-table">
          <thead>
            <tr>
              <th>{{localize "DSRESOURCES.Table.Threshold"}}</th>
              <th>{{localize "DSRESOURCES.Table.Effect"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each passiveEffects}}
            <tr class="{{#if this.isActive}}dsresources-passive-active{{/if}}">
              <td class="dsresources-passive-threshold">{{this.threshold}}</td>
              <td>{{{this.description}}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{/if}}
      </div>
      {{/if}}

      {{!-- Reset button --}}
      <div class="dsresources-footer">
        <button type="button" class="dsresources-btn dsresources-btn--danger" data-action="resetHeroic">
          <i class="fa-solid fa-rotate-left"></i>
          {{localize "DSRESOURCES.Action.Reset"}}
        </button>
      </div>

      {{/if}} {{!-- /noClassData --}}
    </div>
    {{/if}}

    {{!-- ════════════════════════════════════════════════════════════════
         SURGE TAB
         ════════════════════════════════════════════════════════════════ --}}
    {{#if (eq activeTab "surge")}}
    <div class="dsresources-tab-pane" data-tab="surge">

      {{!-- ── Surge Spend: Extra Damage ───────────────────────────────── --}}
      <div class="dsresources-section">
        <h3 class="dsresources-section-title">{{localize "DSRESOURCES.Section.Spend"}}</h3>
        <div class="dsresources-entry">
          <span class="dsresources-entry-desc">{{localize "DSRESOURCES.Surge.DamageDesc"}}</span>
          <div class="dsresources-entry-btn-group">
            <button type="button" class="dsresources-entry-btn dsresources-entry-btn--spend"
              data-action="spendSurgeDamage" data-surge-count="1">
              -1
            </button>
            <button type="button" class="dsresources-entry-btn dsresources-entry-btn--spend"
              data-action="spendSurgeDamage" data-surge-count="2">
              -2
            </button>
            <button type="button" class="dsresources-entry-btn dsresources-entry-btn--spend"
              data-action="spendSurgeDamage" data-surge-count="3">
              -3
            </button>
          </div>
        </div>
        <div class="dsresources-entry">
          <span class="dsresources-entry-desc">{{localize "DSRESOURCES.Surge.PotencyDesc"}}</span>
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--spend"
            data-action="spendSurgePotency">
            -2
          </button>
        </div>
      </div>

      <div class="dsresources-footer">
        <button type="button" class="dsresources-btn dsresources-btn--danger" data-action="resetSurge">
          <i class="fa-solid fa-rotate-left"></i>
          {{localize "DSRESOURCES.Action.Reset"}}
        </button>
      </div>

    </div>
    {{/if}}

    {{!-- ════════════════════════════════════════════════════════════════
         HERO TOKEN TAB
         ════════════════════════════════════════════════════════════════ --}}
    {{#if (eq activeTab "heroToken")}}
    <div class="dsresources-tab-pane" data-tab="heroToken">

      <div class="dsresources-section">
        <h3 class="dsresources-section-title">{{localize "DSRESOURCES.Section.Spend"}}</h3>

        <div class="dsresources-entry">
          <span class="dsresources-entry-desc">{{localize "DSRESOURCES.HeroToken.SurgeDesc"}}</span>
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--herotoken"
            data-action="spendTokenSurge">
            <i class="fa-solid fa-coins"></i> -1
          </button>
        </div>

        <div class="dsresources-entry">
          <span class="dsresources-entry-desc">{{localize "DSRESOURCES.HeroToken.SaveDesc"}}</span>
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--herotoken"
            data-action="spendTokenSave">
            <i class="fa-solid fa-coins"></i> -1
          </button>
        </div>

        <div class="dsresources-entry">
          <span class="dsresources-entry-desc">{{localize "DSRESOURCES.HeroToken.RerollDesc"}}</span>
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--herotoken"
            data-action="spendTokenReroll">
            <i class="fa-solid fa-coins"></i> -1
          </button>
        </div>

        <div class="dsresources-entry">
          <span class="dsresources-entry-desc">{{localize "DSRESOURCES.HeroToken.RecoveryDesc" recoveryValue=recoveryValue}}</span>
          <button type="button" class="dsresources-entry-btn dsresources-entry-btn--herotoken"
            data-action="spendTokenRecovery">
            <i class="fa-solid fa-coins"></i> -2
          </button>
        </div>
      </div>

      <hr class="dsresources-divider" />

      <div class="dsresources-section">
        <p class="dsresources-entry-desc" style="font-style: italic; padding: 4px;">{{localize "DSRESOURCES.HeroToken.LimitNote"}}</p>
      </div>

    </div>
    {{/if}}

  </section>

  {{/if}} {{!-- /noCharacter --}}
</div>
